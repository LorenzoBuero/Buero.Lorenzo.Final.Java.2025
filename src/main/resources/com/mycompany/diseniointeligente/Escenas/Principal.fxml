<?xml version="1.0" encoding="UTF-8"?>

<?import java.net.URL?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ListView?>
<?import javafx.scene.layout.AnchorPane?>

<AnchorPane id="AnchorPane" prefHeight="400.0" prefWidth="600.0" styleClass="mainFxmlClass" xmlns="http://javafx.com/javafx/26" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.mycompany.diseniointeligente.ControladoresUI.PrincipalController">
    <stylesheets>
        <URL value="@/com/mycompany/diseniointeligente/Estilos/principal.css" />
    </stylesheets>
   <children>
      <Button fx:id="btn_editar" layoutX="516.0" layoutY="76.0" mnemonicParsing="false" prefHeight="60.0" prefWidth="70.0" text="Editar" />
      <Button fx:id="btn_cartaNueva" layoutX="14.0" layoutY="354.0" mnemonicParsing="false" onAction="#irAEditorCartas" prefHeight="32.0" prefWidth="200.0" text="Carta Nueva" />
      <Button fx:id="btn_eliminar" layoutX="516.0" layoutY="274.0" mnemonicParsing="false" prefHeight="60.0" prefWidth="70.0" text="Eliminar" />
      <Button fx:id="btn_filtros" layoutX="15.0" layoutY="14.0" mnemonicParsing="false" onAction="#mostrarSelectorFiltros" prefHeight="26.0" prefWidth="200.0" text="Filtros" />
      <Label fx:id="descripcionCarta" alignment="TOP_LEFT" layoutX="227.0" layoutY="27.0" prefHeight="332.0" prefWidth="265.0" text="Sin cartas seleccionadas" />
      <Button fx:id="btn_verImagen" layoutX="317.0" layoutY="357.0" mnemonicParsing="false" text="verImagen" />
